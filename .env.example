# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js — generate a strong random string for AUTH_SECRET
# (e.g., `openssl rand -base64 32`)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (optional — only needed if you enable "Sign in with Google")
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Postgres — these values match docker-compose.yml defaults
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_dev_password
POSTGRES_DB=chatbot
# Override POSTGRES_HOST_PORT if 5432 is taken on your host (e.g., you
# already have Postgres.app or EDB Postgres running locally). Set it to a
# free port (e.g., 5433) and update DATABASE_URL to match.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://chatbot:chatbot_dev_password@localhost:5432/chatbot

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible — MinIO locally, AWS S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=chatbot-documents
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ─── LLM providers ─────────────────────────────────────────────
# Two independent knobs:
#   CHAT_PROVIDER      — streams the chat answer to the user
#   EMBEDDING_PROVIDER — turns chunks into searchable vectors
# They can differ. The chunk.embedding column is fixed at 1536 dims;
# smaller native vectors get zero-padded.
CHAT_PROVIDER=openai
# Options: openai | anthropic | google | deepseek | ollama

EMBEDDING_PROVIDER=openai
# Options: openai | google | ollama

# OpenAI — fill only if any provider above is `openai`
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Claude) — chat only
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest

# Google (Gemini) — chat + embeddings (text-embedding-004 is 768-dim, padded)
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=gemini-1.5-flash
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# Deepseek — OpenAI-compatible API, chat only
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Ollama — fully local. Run `ollama serve` then `ollama pull llama3.2` and
# `ollama pull nomic-embed-text`. No API key required.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Stripe (optional — billing UI shows a "not configured" state without these)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from the webhook endpoint page on the dashboard. Required if
# STRIPE_SECRET_KEY is set, else the webhook handler refuses to process.
STRIPE_WEBHOOK_SECRET=
# Stripe Price ids for each paid tier
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
