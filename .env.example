# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js — generate a strong random string for AUTH_SECRET
# (e.g., `openssl rand -base64 32`)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (optional — only needed if you enable "Sign in with Google")
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Postgres — these values match docker-compose.yml defaults
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_dev_password
POSTGRES_DB=chatbot
# Override POSTGRES_HOST_PORT if 5432 is taken on your host (e.g., you
# already have Postgres.app or EDB Postgres running locally). Set it to a
# free port (e.g., 5433) and update DATABASE_URL to match.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://chatbot:chatbot_dev_password@localhost:5432/chatbot

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible — MinIO locally, AWS S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=chatbot-documents
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# LLM provider (used by Milestone 3+)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
