{
  "name": "ai-chatbot-saas",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-tenant RAG chatbot SaaS — upload PDFs/URLs, get an embeddable AI support widget trained on your content.",
  "license": "MIT",
  "homepage": "https://github.com/cyberunite/ai-chatbot-saas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberunite/ai-chatbot-saas.git"
