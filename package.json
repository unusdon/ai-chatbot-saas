{
  "name": "ai-chatbot-saas",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source multi-tenant RAG chatbot SaaS. Upload PDF/DOCX/XLSX/JSON/MD/URLs/sitemaps/Q&A, pick any LLM (OpenAI/Claude/Gemini/Deepseek/Ollama), deploy across embed widget + Telegram (private + groups) + WhatsApp Cloud API. Full conversation admin with promote-to-training.",
  "license": "MIT",
  "homepage": "https://github.com/unusdon/ai-chatbot-saas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unusdon/ai-chatbot-saas.git"
  },
  "bugs": {
    "url": "https://github.com/unusdon/ai-chatbot-saas/issues"
  },
  "author": {
    "name": "Cyberunite",
    "email": "info@cyberunite.com",
    "url": "https://cyberunite.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run widget:build && next build",
    "build:next": "next build",
    "widget:build": "vite build --config widget/vite.config.ts",
    "widget:dev": "vite --config widget/vite.config.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx worker/index.ts",
    "worker:dev": "tsx watch worker/index.ts"
  },
